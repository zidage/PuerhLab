---
import { t } from '../i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const i = t(lang);
---

<section
  id="contribute"
  class="relative py-24 px-4 bg-deep/50 overflow-hidden"
>
  <!-- Background glow -->
  <div
    class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[400px] bg-gold/5 rounded-full blur-3xl pointer-events-none"
  >
  </div>

  <div class="relative max-w-3xl mx-auto text-center reveal">
    <h2 class="text-3xl sm:text-4xl font-bold text-mist mb-4">
      {i.contributing.sectionTitle}
    </h2>
    <div class="w-16 h-0.5 bg-gold mx-auto mb-6"></div>
    <p class="text-muted text-lg mb-10 max-w-xl mx-auto">
      {i.contributing.description}
    </p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://github.com/zidage/PuerhLab"
        target="_blank"
        rel="noopener noreferrer"
        class="px-8 py-3 bg-gold text-canvas font-semibold rounded-panel hover:bg-gold/90 transition-all hover:shadow-[0_0_24px_rgba(252,199,4,0.3)] flex items-center gap-2"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
        {i.contributing.ctaGithub}
      </a>
      <a
        href="https://github.com/zidage/PuerhLab/blob/main/README.md"
        target="_blank"
        rel="noopener noreferrer"
        class="px-8 py-3 border border-gold text-gold font-semibold rounded-panel hover:bg-gold/10 transition-all"
      >
        {i.contributing.ctaDocs}
      </a>
    </div>
  </div>
</section>
