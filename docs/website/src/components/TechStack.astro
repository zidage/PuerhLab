---
import { t } from '../i18n';

interface Props {
  lang: string;
}

const { lang } = Astro.props;
const i = t(lang);
const sectionLabel = lang === 'zh' ? '技术栈' : 'BUILT WITH';
---

<section id="tech-stack" class="relative py-28 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Section header -->
    <div class="mb-14 reveal">
      <div class="flex items-center gap-3 mb-4">
        <span class="section-label eyebrow-line">{sectionLabel}</span>
      </div>
      <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-3">
        <h2 class="font-display text-3xl sm:text-4xl lg:text-[42px] font-semibold text-mist leading-tight">
          {i.techStack.sectionTitle}
        </h2>
        <p class="text-muted text-[15px] max-w-md md:text-right">
          {i.techStack.sectionSubtitle}
        </p>
      </div>
    </div>

    <!-- Category rows — library-filter style -->
    <div class="rounded-panel ring-1 ring-separator bg-panel/40 divide-y divide-separator/80 overflow-hidden">
      {
        i.techStack.categories.map((cat, catIdx) => (
          <div
            class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8 px-6 py-5 reveal"
            style={`transition-delay: ${catIdx * 80}ms`}
          >
            <div class="md:w-48 shrink-0">
              <h3 class="font-display text-[11px] tracking-label uppercase text-stats-muted">
                {cat.label}
              </h3>
            </div>
            <div class="flex flex-wrap gap-2">
              {cat.items.map((item) => (
                <span class="tech-pill">{item}</span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .tech-pill {
    @apply inline-flex items-center px-3.5 py-1.5 rounded-pill text-[13px] font-medium
           text-mist/90 bg-card/60 ring-1 ring-separator
           hover:text-action hover:ring-action/50 hover:bg-action-tint
           transition-all duration-200 cursor-default;
    font-family: 'Manrope', sans-serif;
  }
</style>
