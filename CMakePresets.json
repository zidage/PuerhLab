{
  "version": 3,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 21
  },
  "configurePresets": [
    {
      "name": "win_debug",
      "displayName": "Debug Build",
      "description": "Windows: Build with debug info",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake"
      }
    },
    {
      "name": "win_release",
      "displayName": "Release Build",
      "description": "Windows: Build release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_TOOLCHAIN_FILE": "${sourceDir}/vcpkg/scripts/buildsystems/vcpkg.cmake",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/install"
      }
    },
    {
      "name": "debug",
      "displayName": "Debug Build",
      "description": "Build with debug info",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug"
      }
    },
    {
      "name": "release",
      "displayName": "Release Build",
      "description": "Build release",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "macos_debug",
      "displayName": "macOS Debug",
      "description": "macOS: CPU-only app build without the OpenGL editor",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PUERHLAB_ENABLE_CUDA": "OFF",
        "PUERHLAB_ENABLE_OPENGL_EDITOR": "OFF",
        "PUERHLAB_BUILD_TESTS": "OFF"
      }
    },
    {
      "name": "macos_debug_tests",
      "displayName": "macOS Debug Tests",
      "description": "macOS: Debug test build for CMake Tools and clangd",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-debug-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PUERHLAB_ENABLE_CUDA": "OFF",
        "PUERHLAB_ENABLE_OPENGL_EDITOR": "OFF",
        "PUERHLAB_BUILD_TESTS": "ON"
      }
    },
    {
      "name": "macos_release",
      "displayName": "macOS Release",
      "description": "macOS: CPU-only app build without the OpenGL editor",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/macos-release",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON",
        "PUERHLAB_ENABLE_CUDA": "OFF",
        "PUERHLAB_ENABLE_OPENGL_EDITOR": "OFF",
        "PUERHLAB_BUILD_TESTS": "OFF",
        "CMAKE_INSTALL_PREFIX": "${sourceDir}/build/install"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "win_debug",
      "configurePreset": "win_debug",
      "jobs": 8
    },
    {
      "name": "win_release",
      "configurePreset": "win_release",
      "jobs": 8
    },
    {
      "name": "debug",
      "configurePreset": "debug",
      "jobs": 8
    },
    {
      "name": "release",
      "configurePreset": "release",
      "jobs": 8
    },
    {
      "name": "macos_debug",
      "configurePreset": "macos_debug",
      "jobs": 8
    },
    {
      "name": "macos_debug_tests",
      "configurePreset": "macos_debug_tests",
      "jobs": 8
    },
    {
      "name": "macos_release",
      "configurePreset": "macos_release",
      "jobs": 8
    }
  ],
  "testPresets": [
    {
      "name": "macos_debug_tests",
      "configurePreset": "macos_debug_tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}
